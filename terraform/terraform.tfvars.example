aws_region        = "us-east-2"
project_name      = "vibe-coded-protected"
environment       = "dev"
vpc_id            = "vpc-0123456789abcdef0"
public_subnet_ids = ["subnet-11111111111111111", "subnet-22222222222222222"]
private_subnet_ids = [
  "subnet-33333333333333333",
  "subnet-44444444444444444",
]
db_subnet_ids = [
  "subnet-33333333333333333",
  "subnet-44444444444444444",
]

ecs_launch_type       = "EC2"
container_registry_type = "ecr"
container_image_tag     = "bootstrap"

allowed_ingress_cidrs = ["0.0.0.0/0"]

app_environment = {
  APP_NAME = "Vibe Coded Protected API"
  DEBUG    = "false"
}

ecs_service_desired_count = 2
ecs_service_min_capacity  = 2
ecs_service_max_capacity  = 6

ec2_instance_type    = "t3.small"
ec2_desired_capacity = 2
ec2_min_size         = 2
ec2_max_size         = 4

db_instance_class             = "db.t4g.micro"
db_allocated_storage          = 20
db_max_allocated_storage      = 100
db_backup_retention_period    = 7
db_multi_az                   = false
db_deletion_protection        = true
db_skip_final_snapshot        = false
db_performance_insights_enabled = false

cloudwatch_log_retention_in_days = 30
enable_waf                       = true
waf_rate_limit                   = 1000

# Optional HTTPS and DNS
# acm_certificate_arn = "arn:aws:acm:us-east-2:123456789012:certificate/00000000-0000-0000-0000-000000000000"
# route53_zone_id     = "Z0123456789ABCDEFG"
# domain_name         = "api.example.com"

# Docker Hub option instead of ECR
# container_registry_type          = "dockerhub"
# container_image_repository       = "your-dockerhub-org/vibe-coded-protected"
# dockerhub_credentials_secret_arn = "arn:aws:secretsmanager:us-east-2:123456789012:secret:dockerhub-creds"
