# Application Settings
APP_NAME=Vibe Coded Protected API
DEBUG=true

# Database Settings
# IMPORTANT: Change these values in production!
# NEVER commit actual credentials to version control
POSTGRES_USER=vibeuser
POSTGRES_PASSWORD=vibepass
POSTGRES_DB=vibedb
POSTGRES_PORT=5432

# Database URL (used by application)
DATABASE_URL=postgresql://vibeuser:vibepass@db:5432/vibedb

# Web Server Settings
WEB_PORT=8000
HOST=0.0.0.0
PORT=8000
